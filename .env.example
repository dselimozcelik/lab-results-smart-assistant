# docker-compose.full.yml ortam değişkenleri.
# Bu dosyayı `.env` olarak kopyalayıp değerleri doldurun; Compose `.env`'i otomatik okur.
#   cp .env.example .env
# Alternatif: değişkenleri shell'de export edip compose'u öyle çalıştırın.

# --- ZORUNLU ---
# JWT imzalama anahtarı. Public/varsayılan değer YOKTUR: boşsa Compose başlamaz,
# 32 karakterden kısaysa backend startup'ta fail-fast yapar.
# Kriptografik rastgele bir değer üretin:  openssl rand -base64 48
JWT_SECRET=

# --- OPSİYONEL (varsayılanları aşağıda) ---

# AI ön analizi için Ollama modeli. Host'taki Ollama'da `ollama pull` ile indirilmiş olmalı.
OLLAMA_MODEL=gemma2:9b

# Backend CORS için izin verilen frontend origin'i.
FRONTEND_ORIGIN=http://localhost:5173

# Backend'in mock cihazdan veri çekme aralığı (ms). Daha hızlı demo için düşürün, örn. 5000.
POLLING_DELAY_MS=30000

# Frontend'in backend'den veri çekme aralığı (ms, build-time). POLLING_DELAY_MS'ten
# bağımsızdır; canlı akış demosu için ikisini aynı değere ayarlayın. Boşsa varsayılan 30000.
VITE_REFETCH_MS=

# Host port eşlemeleri. Port çakışması varsa değiştirin.
FRONTEND_PORT=5173
BACKEND_PORT=8080
MOCK_LAB_PORT=8081

# Frontend build-time API base URL. Boş bırakılırsa same-origin (nginx /api proxy) kullanılır.
VITE_API_BASE_URL=
