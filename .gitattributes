# Normalize line endings so a Windows checkout does not corrupt scripts.
* text=auto eol=lf

# Scripts that must stay LF even on Windows (run inside Docker / by sh).
*.sh text eol=lf
mvnw text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
nginx.conf text eol=lf
Dockerfile text eol=lf

# Windows-only launchers must stay CRLF.
*.cmd text eol=crlf
*.bat text eol=crlf

# Binary assets: never touch.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.jar binary
